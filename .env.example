# 服务器配置
PORT=40000
NODE_ENV=development
# 允许多个来源，使用逗号分隔；设置为 * 允许任意来源
# 如果未配置则自动允许当前服务端口（如 http://localhost:40000）
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 数据配置
DATA_PATH=./server/GD
MAX_BATCH_SIZE=20000
BATCH_CHUNK_SIZE=500

# 日志配置
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
# 是否开启 HSTS（仅在部署 HTTPS 入口时启用）
ENABLE_HSTS=false

# 前端配置
VITE_API_BASE_URL=/api/v1
VITE_BATCH_CHUNK_SIZE=500
VITE_MAX_BATCH_SIZE=20000
VITE_MAX_FILE_SIZE=10485760
